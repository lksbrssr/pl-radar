# Copy to `.env` and fill in. NEVER commit the real .env (it is git-ignored).

# --- Required ---
# Telegram bot token from @BotFather (run /newbot, then paste the token here).
BOT_TOKEN=123456:ABC-your-token-here

# --- Optional ---
# Where the SQLite file lives. Default is ./.data/radar.sqlite (git-ignored).
# On Fly.io this points at the mounted volume, e.g. /data/radar.sqlite
DATABASE_PATH=.data/radar.sqlite

# HTTP port for /health and the public results API. Fly/PLN set PORT for us.
PORT=3000

# Comma-separated Telegram user IDs allowed to run admin commands
# (/stats, /leaderboard, /broadcast). Find your id via @userinfobot.
ADMIN_IDS=

# How many pair comparisons make up one daily round (default 3).
ROUND_SIZE=3

# --- AI card submission (optional) ---
# The web app lets people paste a URL (a news article, a Reddit/X post, a paper)
# and have an LLM turn it into a candidate card they can review. Because that
# burns AI tokens, the whole submit surface is OFF until you set SUBMIT_KEY.
# SUBMIT_KEY is just an on/off switch: any non-empty value turns the submit
# surface ON for everyone (no passphrase to enter); abuse is limited by per-IP
# rate limits instead. Leave it blank to keep the surface off and never burn
# tokens.
SUBMIT_KEY=

# The model that parses the pasted URL. Set EITHER an Anthropic key OR an
# OpenAI-compatible key. Provider auto-detects (or pin it with LLM_PROVIDER).
# With no key, AI parse is unavailable and the UI falls back to the manual /
# bring-your-own-agent path.
# LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
