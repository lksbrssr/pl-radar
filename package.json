{
  "name": "plrd-radar-curator",
  "version": "0.1.0",
  "private": true,
  "description": "Crowd-curation Telegram bot for the PL R&D Radar. Curators vote on pairs of candidate cards (king-of-the-hill); Elo + segmented analysis surface the strongest signal for the public Radar.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json && cp src/db/schema.sql dist/db/schema.sql",
    "seed": "tsx src/seed/run.ts",
    "simulate": "tsx src/dev/simulate.ts",
    "dev:serve": "tsx src/dev/serve.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.100",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "grammy": "^1.34.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
